# --- SMTP ----------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_APP_PASSWORD
SMTP_FROM_EMAIL=your-smtp-user@example.com
SMTP_FROM_NAME="HPYS Verification"

# --- WhatsApp Cloud API --------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=CHANGE_ME_WHATSAPP_TOKEN
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCOUNT_ID=CHANGE_ME_BUSINESS_ACCOUNT_ID
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_VERIFY_TOKEN

# --- AWS S3 media uploads (optional). Empty = local ./data/uploads fallback ----
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Optional ------------------------------------------------------------------
# LUDOKING_API_KEY=

# --- Bundled MySQL only (unused when COMPOSE_PROFILES is empty) ----------------
# MYSQL_ROOT_PASSWORD=
# MYSQL_INNODB_BUFFER_POOL=512M

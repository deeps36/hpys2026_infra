# =============================================================================
# HPYS 2026 — Production environment template (Oracle ARM + Hostinger MySQL)
# Copy to .env and fill in real values. NEVER commit .env with secrets.
# =============================================================================

# --- Compose build paths (server layout under /opt/hpys) ------------------------
FRONTEND_DIR=./frontend
BACKEND_DIR=./backend
IMAGE_TAG=latest
# Branch used by deploy.sh when updating frontend/ + backend/ clones
DEPLOY_BRANCH=main

# --- MySQL mode ----------------------------------------------------------------
# EXTERNAL Hostinger MySQL (recommended for this deployment):
#   Leave COMPOSE_PROFILES empty / unset — do NOT set local-mysql.
# BUNDLED MySQL container (optional / local only):
#   COMPOSE_PROFILES=local-mysql
#   DB_HOST=mysql
#
# IMPORTANT: leave the next line empty or omit it for Hostinger.
COMPOSE_PROFILES=

# --- Public URLs (baked into frontend image at BUILD time) ---------------------
# MUST include the /api suffix — the SPA appends paths like /reels → /api/reels.
# Example for dedicated API host:
#   VITE_API_BASE_URL=https://api26.hpys.in/api
#   VITE_BACKEND_URL=https://api26.hpys.in
VITE_API_BASE_URL=https://your-domain.com/api
VITE_BACKEND_URL=https://your-domain.com

# --- File Browser (https://files.hpys.in) --------------------------------------
FILEBROWSER_USERNAME=admin
FILEBROWSER_PASSWORD=Gunatit@3690
FILEBROWSER_PUBLIC_URL=https://files.hpys.in
FILEBROWSER_IMAGE=filebrowser/filebrowser:v2.32.0

# --- Upload size ---------------------------------------------------------------
# Nginx client_max_body_size for hpys.in / www / api26 / files
UPLOAD_MAX_SIZE=20G
# Multer cap in bytes (20GiB) — keep in sync with UPLOAD_MAX_SIZE
UPLOAD_MAX_BYTES=21474836480
# JSON_BODY_LIMIT=100mb
# Raise if you routinely upload multi‑GB reels into memory (multer memoryStorage)
# BACKEND_MEM_LIMIT=4096m

# --- Backend runtime -----------------------------------------------------------
NODE_ENV=production
PORT=8000

# --- Hostinger remote MySQL ----------------------------------------------------
# Hostname only — never use https://... here.
DB_HOST=srv1953.hstgr.io
DB_PORT=3306

# Replace with your Hostinger database / user names from hPanel
DB_DATABASE=u914595671_hpys_db
DB_USERNAME=u914595671_hpys_db
DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG

# Hostinger max_connections_per_hour: keep limit low, keep idle sockets warm
DB_CONNECTION_LIMIT=3
DB_POOL_MAX_IDLE=3
DB_POOL_IDLE_TIMEOUT_MS=28800000
DB_POOL_QUEUE_LIMIT=100
DB_CONNECT_TIMEOUT_MS=15000

# Backend aliases (compose falls back to DB_* if you omit these)
LOCAL_DB_HOST=srv1953.hstgr.io
LOCAL_DB_PORT=3306
LOCAL_DB_DATABASE=u914595671_hpys_db
LOCAL_DB_USERNAME=u914595671_hpys_db
LOCAL_DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG

PROD_DB_HOST=srv1953.hstgr.io
PROD_DB_PORT=3306
PROD_DB_DATABASE=u914595671_hpys_db
PROD_DB_USERNAME=u914595671_hpys_db
PROD_DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG

# --- Reels sharding (same Hostinger host; per-DB users/names from hPanel) ------
REELS_DB_COUNT=6
REELS_DB_LIMIT_BYTES=3221225472

REELS_METADATA_DB_HOST=srv1953.hstgr.io
REELS_METADATA_DB_PORT=3306
REELS_METADATA_DB_NAME=u914595671_hpys_metadata
REELS_METADATA_DB_USER=u914595671_hpys_metadata
REELS_METADATA_DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG

REELS_DB_1_HOST=srv1953.hstgr.io
REELS_DB_1_PORT=3306
REELS_DB_1_USER=u914595671_hpys_reels_1
REELS_DB_1_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
REELS_DB_1_NAME=u914595671_hpys_reels_1

REELS_DB_2_HOST=srv1953.hstgr.io
REELS_DB_2_PORT=3306
REELS_DB_2_USER=u914595671_hpys_reels_2
REELS_DB_2_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
REELS_DB_2_NAME=u914595671_hpys_reels_2

REELS_DB_3_HOST=srv1953.hstgr.io

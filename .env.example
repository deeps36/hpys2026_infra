# =============================================================================
# HPYS 2026 — Production environment template
# Copy to .env and fill in real values. NEVER commit .env with secrets.
# =============================================================================

# --- Compose build paths -------------------------------------------------------
# Production server (/opt/hpys with frontend/ + backend/ folders):
FRONTEND_DIR=./frontend
BACKEND_DIR=./backend
# Monorepo workspace (this repository):
# FRONTEND_DIR=./hpys2026_frontend
# BACKEND_DIR=./hpys2026_backend

# Image tag used by compose + deploy.sh rollback snapshots (:previous)
IMAGE_TAG=latest

# Include bundled MySQL container (omit for external/Hostinger MySQL):
# COMPOSE_PROFILES=local-mysql

# MySQL InnoDB buffer pool (keep ≤ ~50% of container memory limit; local-mysql only)
MYSQL_INNODB_BUFFER_POOL=512M

# --- Public URLs (baked into frontend at build time) ---------------------------
# Examples behind Cloudflare + host Nginx:
VITE_API_BASE_URL=https://your-domain.com/api
VITE_BACKEND_URL=https://your-domain.com

# --- Backend runtime -----------------------------------------------------------
NODE_ENV=production
PORT=8000

# --- MySQL --------------------------------------------------------------------
# Bundled Compose MySQL: DB_HOST=mysql + COMPOSE_PROFILES=local-mysql
# External MySQL: set DB_HOST to hostname/IP (NOT an https:// website URL)
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_STRONG

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hpys_db
DB_USERNAME=hpys
DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG

# Aliases used by backend config (db.js / scripts) — default to DB_* if unset in compose
LOCAL_DB_HOST=mysql
LOCAL_DB_PORT=3306
LOCAL_DB_DATABASE=hpys_db
LOCAL_DB_USERNAME=hpys
LOCAL_DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG

PROD_DB_HOST=mysql
PROD_DB_PORT=3306
PROD_DB_DATABASE=hpys_db
PROD_DB_USERNAME=hpys
PROD_DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG

# --- Reels sharding ------------------------------------------------------------
REELS_DB_COUNT=6
REELS_DB_LIMIT_BYTES=3221225472

REELS_METADATA_DB_HOST=mysql
REELS_METADATA_DB_PORT=3306
REELS_METADATA_DB_NAME=hpys_reels_metadata
REELS_METADATA_DB_USER=hpys
REELS_METADATA_DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG

REELS_DB_1_HOST=mysql
REELS_DB_1_PORT=3306
REELS_DB_1_USER=hpys
REELS_DB_1_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
REELS_DB_1_NAME=hpys_reels_db_1

REELS_DB_2_HOST=mysql
REELS_DB_2_PORT=3306
REELS_DB_2_USER=hpys
REELS_DB_2_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
REELS_DB_2_NAME=hpys_reels_db_2

REELS_DB_3_HOST=mysql
REELS_DB_3_PORT=3306
REELS_DB_3_USER=hpys
REELS_DB_3_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
REELS_DB_3_NAME=hpys_reels_db_3

REELS_DB_4_HOST=mysql
REELS_DB_4_PORT=3306
REELS_DB_4_USER=hpys
REELS_DB_4_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
REELS_DB_4_NAME=hpys_reels_db_4

REELS_DB_5_HOST=mysql
REELS_DB_5_PORT=3306
REELS_DB_5_USER=hpys
REELS_DB_5_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
REELS_DB_5_NAME=hpys_reels_db_5

REELS_DB_6_HOST=mysql
REELS_DB_6_PORT=3306
REELS_DB_6_USER=hpys
REELS_DB_6_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
REELS_DB_6_NAME=hpys_reels_db_6

# --- Profile image database ----------------------------------------------------
PROFILE_DB_HOST=mysql
PROFILE_DB_PORT=3306
PROFILE_DB_NAME=hpys_profile_img
PROFILE_DB_USER=hpys
PROFILE_DB_PASSWORD=CHANGE_ME_APP_PASSWORD_STRONG
PROFILE_DB_LIMIT_BYTES=3221225472

# --- SMTP ----------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_APP_PASSWORD
SMTP_FROM_EMAIL=your-smtp-user@example.com
SMTP_FROM_NAME="HPYS Verification"

# --- WhatsApp Cloud API --------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=CHANGE_ME_WHATSAPP_TOKEN
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCOUNT_ID=CHANGE_ME_BUSINESS_ACCOUNT_ID
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_VERIFY_TOKEN

# --- AWS S3 media uploads (optional on awa1.1+) --------------------------------
# If left empty, backend falls back to local /app/uploads (./data/uploads)
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Optional integrations -----------------------------------------------------
# LUDOKING_API_KEY=
